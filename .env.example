# Copy sang .env và điền giá trị thật: cp .env.example .env

# ── PostgreSQL ──
POSTGRES_USER=plately
POSTGRES_PASSWORD=change-me
POSTGRES_DB=plately
POSTGRES_PORT=5432

# Chuỗi kết nối dùng cho app (Next.js) và scripts.
# Phải khớp USER/PASSWORD/DB/PORT ở trên.
DATABASE_URL=postgresql://plately:change-me@localhost:5432/plately

# ── API keys ──
# Gemini: trích ý định từ câu tìm tự nhiên (src/lib/extract.ts). Thiếu -> fallback parse rỗng.
GEMINI_API_KEY=
# Google Places: geocode địa điểm gõ tay -> toạ độ để tính khoảng cách (src/lib/geocode.ts).
# Thiếu -> chỉ tính khoảng cách khi bật định vị thiết bị.
GOOGLE_API_KEY=

# ── Auth.js / NextAuth (đăng nhập Google — src/auth.ts) ──
# Khoá ký session JWT. Sinh bằng: openssl rand -base64 32
AUTH_SECRET=
# OAuth client lấy từ Google Cloud Console (cùng client khai redirect URI bên dưới).
# Redirect URI phải khai ở Console: <origin>/api/auth/callback/google cho từng môi trường.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Email tự cấp quyền admin lần đầu đăng nhập (phân tách bằng dấu phẩy).
ADMIN_EMAILS=

# ── Auth.js sau reverse proxy (chỉ deploy, KHÔNG cần ở localhost) ──
# localhost:3000 chạy thẳng -> bỏ trống cả hai. Khi chạy sau proxy (vd dev.platelyai.xyz
# -> localhost:4000) NextAuth không tin Host từ proxy và sẽ báo lỗi UntrustedHost.
# AUTH_TRUST_HOST=true: cho phép tin Host/X-Forwarded-Host từ proxy.
AUTH_TRUST_HOST=
# AUTH_URL: ghim URL công khai để callback dựng đúng domain (không lệ thuộc host forward),
# tránh redirect_uri_mismatch. Ví dụ deploy dev: https://dev.platelyai.xyz
AUTH_URL=
