# Copy sang .env và điền giá trị thật: cp .env.example .env

# ── PostgreSQL ──
POSTGRES_USER=plately
POSTGRES_PASSWORD=change-me
POSTGRES_DB=plately
POSTGRES_PORT=5432

# Chuỗi kết nối dùng cho app (Next.js) và scripts.
# Phải khớp USER/PASSWORD/DB/PORT ở trên.
DATABASE_URL=postgresql://plately:change-me@localhost:5432/plately

# ── API keys ──
# Gemini: trích ý định từ câu tìm tự nhiên (src/lib/extract.ts). Thiếu -> fallback parse rỗng.
GEMINI_API_KEY=
# Google Places: geocode địa điểm gõ tay -> toạ độ để tính khoảng cách (src/lib/geocode.ts).
# Thiếu -> chỉ tính khoảng cách khi bật định vị thiết bị.
GOOGLE_API_KEY=
